(defc home []
  (let [l :home]
    [:div.splash
     (header l)
     [:div.body
      (main-nav-links l)
      [:div.intro-text
       "Cindy Baldwin is the author of the critically acclaimed novel"
       [:i "Where The Watermelons Grow"]
       " and the forthcoming "
       [:i "Beginners Welcome"]
       ". She grew up in North Carolina and still misses the sweet watermelons and warm accents on a daily basis. As a middle schooler, she kept a book under her bathroom sink to read over and over while fixing her hair or brushing her teeth, and she dreams of writing the kind of books readers can’t bear to be without. She lives in Portland, Oregon, with her husband and daughter."]]]))

(defc about []
  (let [l :about]
    [:div.content
     [:h1 "About"]
     [:img.highlight {:alt "Cindy Baldwin Headshot" :src "images/headshot1.jpeg"}]
     [:p [:a {:href "/#press-kit"} "Click here to access my press kit."]]
     [:p "For as long as I can remember, I have wanted to tell stories—probably because my imagination was so vivid as a child that I was convinced that the Three Bears slept on the other side of my queen-sized bed and that a volcano was likely to rupture underneath my house at any moment. When I was eight, before computers were nearly as common as they are now, I taught myself how to type so that I could get the stories in my head down faster than I could with a pen and paper. As an adult I type about 150 words per minute, so I guess it paid off!"]
     [:p "I have a genetic disease called cystic fibrosis, and my health challenges have always been both a big part of my life and a big influence on my writing. One of my first books (also written when I was about eight) was a melodrama about a princess locked in a tower that featured villains named most cleverly after two of my inhaled medications (Albuterol and Vanceril, in case you’re wondering)."]
     [:p "As a preteen, I had books stashed all over my house in case I found myself nearby without reading material. For years, I kept a book in one bathroom cabinet in particular, just on the off-chance that I was brushing my teeth or visiting the toilet without another book at hand. (I remember this book most often being either ELLA ENCHANTED by Gail Carson Levine or FAR TO GO by Noel Streatfeild.) As a grown-up, it’s my goal to write the kinds of books that kids will want to stash in bathroom cabinets."]
     [:p "Like many of my characters, I grew up in the South (Durham, North Carolina, to be precise). I moved away after graduating high school and haven’t been back since, but my heart will always love the humidity, lightning bugs, and warm accents."]
     [:p "These days, my home is in Portland, Oregon, which is a different kind of magic—and while I’ll always miss the South, I’m growing to love the misty winters and the wild blackberries, too! I live in a cute little house called Maple Cottage with my husband and preschool-aged daughter, who looks like she just might turn out to be a storyteller, too."]]))

(defc press-kit [all-books]
  (let [sorted-books (sort-books-release all-books)]
    [:div.content
     [:h1 "Press Kit"]
     [:p "Text and images may be used for promotional purposes."]
     [:h2 "Images"]
     [:p "Click to download high-res images."]
     [:div.photo-grid

      [:div
       [:div [:a {:href "images/headshot1.jpeg"} [:img {:alt "Cindy Baldwin Headshot" :src "images/headshot1.jpeg"}]]]
       [:div.text-wrap "Photo Credit Cindy Baldwin."]]
      (for [[_ b] sorted-books]
        (when (and (book-active b)
                   (-> b :images :front-cover))
          [:div
           [:div [:a {:href (-> b :images :front-cover)} [:img.book-img {:src (-> b :images :front-cover)}]]]
           [:div.text-wrap "Cover by " (-> b :images :front-cover-art-credit) "."]]))]
     [:h2 "Bio"]
     [:p "Cindy Baldwin is the author of the critically acclaimed novel " [:i "Where the Watermelons Grow"] " and the forthcoming " [:i "Beginners Welcome"] ". She grew up in North Carolina and still misses the sweet watermelons and warm accents on a daily basis. As a middle schooler, she kept a book under her bathroom sink to read over and over while fixing her hair or brushing her teeth, and she dreams of writing the kind of books readers can’t bear to be without. She lives in Portland, Oregon, with her husband and daughter."]
     [:h2 "Book Details"]
     (for [[_ b] sorted-books]
       (let [released? (> (time-coerce/to-long (time/now)) (time-coerce/to-long (date-from-map (:pub-date b))))
             announced? (> (time-coerce/to-long (time/now)) (time-coerce/to-long (date-from-map (:display-date b))))]
         [:div
          [:h3.title (:title b)]
          [:p (if released? "released" "releases") " " (format-date (:pub-date b))]
          [:p "ISBN: " (:isbn b)]
          [:h4 "Summary"]
          [:p [:b (:summary b)]]
          (for [s (:brief-description b)]
            [:p s])
          (when announced? [:p "For more information about this book, and for a selection of reviews visit this book's page " [:a {:href (:uri b)} "here"] "."])]))]))


(defc events [evs]
  (let [l :events]
    [:div.content
     [:h1 "Events"]
     [:div.events
      (for [e evs]
        (let [name (-> e :location :name)
              link (-> e :location :link)]
          [:div.event
           [:h3.date (str (:date e))]
           (when (and name link)
             [:div.location "Location: " [:a {:href link :target "_blank"} name]])
           [:div.description (:description e)]]))]
     [:div.break]
     [:div.buy-book-notice "If you'd like to have a book signed at any of these events, please plan to purchase the book in-store during the event. This helps support local independent bookstores and keep them thriving!"]]))


(defc short-works [short-works]
  (let [l :short-works]
    [:div.content
     [:h1 "Short Works"]
     "Places my work has appeared:"
     [:ul
      (for [{:keys [title description date publication-title link excerpts]} short-works]
        [:li {:key (str "book_" title)}
         (when title [:span.title "\"" title "\""])
         (when description description)
         " in "
         (if link
           [:a {:href link :target "_blank"} publication-title]
           publication-title)
         (when date (str " (" date ")"))
         (when excerpts
           [:div "Some excerpts:"
            [:ul
             (for [e excerpts]
               [:li [:a {:href (:link e)} (:title e)]])]])])]]))

(defc show-quotes [title quotes location]
  (when-not (empty? quotes)
    [:div.quotes
     (if (= location :top) [:h3 "Praise for " [:i title]]
                           [:h3 "More praise for " [:i title]])
     (for [{:keys [text link]} (filter #(= :indie (:type %)) quotes)]
       [:div [:span.text [:a {:href link :target "_blank"} text]]])
     (for [{:keys [text type author business link newbery-book]} (filter #(not= :indie (:type %)) quotes)]
       [:div {:class (name type)}
        [:span.text
         text
         (when (= :star-review type) " ★")]
        [:span.author
         " ~ "
         author
         (when newbery-book [:span ", Newbery Honor-winning author of " [:i newbery-book]])
         (when (and author business) " from ")
         (if link
           [:a {:href link :target "_blank"}
            business
            (when (= :star-review type) ", Starred Review")]
           business)]])]))


(defc book [{:keys [title subtitle description notes quotes indie pub-date] :as book}]
  [:div
   [:div.content
    [:h1 title (when subtitle [:small subtitle])]
    [:div.book-info
     [:img.book-img {:src (-> book :images :front-cover)}]
     (affiliates/affiliate-link-list book)]
    (show-quotes title (filter #(= (:location %) :top) quotes) :top)
    (for [d description]
      (let [key (string/replace (subs d 0 15) #"\s" "_")]
        [:p {:key key} d]))
    (show-quotes title (filter #(not= (:location %) :top) quotes) :bottom)]
   [:div.break]
   notes])

(defc books-list [all-books]
  (let [book-vec (->> all-books
                      (map second)
                      (filter #(book-active %))
                      sort-books-release)]
    [:div.content
     [:div
      (for [{:keys [title uri summary description brag] :as book} book-vec]
        [:div.clear.book-info-summary
         [:div.book-info [:a {:href uri} [:img.book-img {:src (-> book :images :front-cover)}]]]
         [:a {:href uri} [:h2 title]]
         (when brag
           [(for [b brag]
              [:h3.plain b])])
         [:p summary]
         [:p (first description) " "
          [:a {:href uri} "Click here for more info."]]])]]))

(defc books
  "Displays the book requested, or a list of books."
  [all-books book-id]
  (let [disp-book (when book-id ((keyword book-id) all-books))];todo if title is close to the name of the book select it
    (if (and disp-book (:active disp-book))
      (book disp-book)
      (books-list all-books))))


