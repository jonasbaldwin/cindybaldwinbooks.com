; ################################# root

(defc root < rum/reactive []
  (let [l (-> (rum/react location) :handler)
        book-id (-> (rum/react location) :route-params :book-id)
        all-books (-> (rum/react state) :all-books)
        all-short-works (-> (rum/react state) :all-short-works :short-works)
        all-events (-> (rum/react state) :all-events :events)]
    [:.application
     (when (not= l :home)
       (header l))
     (when (not= l :home)
       (main-nav-links l))
     (case l
       :home (home)
       :about (about)
       :press-kit (press-kit all-books)
       :events (loading all-events (events all-events))
       :short-works (loading all-events (short-works all-short-works))
       :books (loading all-events (books all-books book-id))
       :book-club (book-club)
       :class-resources (class-resources))
     (social)]))

(defn mount []
  (rum/mount (root) (.getElementById js/document "app"))
  (rum/mount (root) (.getElementById js/document "app")))

(mount)
