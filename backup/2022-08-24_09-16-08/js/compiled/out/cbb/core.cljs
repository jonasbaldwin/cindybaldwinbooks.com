(def router
  (start-router!
    ["" {"home"            :home
         "about"           :about
         "events"          :events
         "short-works"     :short-works
         "blog-resources"  :blog-resources
         "book-club"       :book-club
         "terms"           :terms
         "class-resources" :class-resources
         "press-kit"       :press-kit
         "books"           {""             :books
                            "/"            :books
                            ["/" :book-id] :books}}]
    {:on-navigate #(reset! location (or % {:handler :home}))}))


(defonce state (atom {}))


(defn update-state [k r]
  (swap! state assoc k (reader/read-string r)))

(defn load [file k]
  (ajax/GET file {:response-format :text
                  :handler         #(update-state k %)}))

(load "data/books.edn" :all-books)
(load "data/short_works.edn" :all-short-works)
(load "data/events.edn" :all-events)

