; ################################# helpers

(def custom-formatter (time-format/formatter "MMMM do, yyyy"))

(defn date-from-map [{:keys [day month year]}]
  (time/date-time year month day))

(defn format-date [date]
  (time-format/unparse default-formatter (date-from-map date)))

(defn book-active [book]
  (and (:active book) (> (time/now) (date-from-map (:display-date book)))))

(defn sort-books-release [all-books]
  (sort (fn [_ {:keys [pub-date]}]
          (str (:year pub-date) (:month pub-date) (:day pub-date)))
        all-books))


