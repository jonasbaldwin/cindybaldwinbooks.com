(defn replace-youtube [markdown-text]
  (let [re #"!YT\<(?<vid>[\w-]*),(?<title>[\w\s]*)\>"
        vid-matches (map zipmap (repeat [:full :vid :title]) (re-seq re markdown-text))]
    (reduce (fn [p c]
              (let [replace-regex (-> (:full c)
                                      (string/replace #"\(" "<")
                                      (string/replace #"\)" ">")
                                      (re-pattern))]
                (string/replace p replace-regex (embeded-youtube-html {:platform :youtube :title (:title c) :video-id (:vid c)}))))
            markdown-text
            vid-matches)))

(defn replace-book-resources [markdown-text all-books]
  (let [book-vec (->> all-books
                      (map second)
                      (filter #(book-active %))
                      sort-books-release)
        re #"!!BOOK_RESOURCES"
        re-matches (re-seq re markdown-text)]
    (reduce (fn [p c]
              (let [replace-regex (re-pattern c)]
                (string/replace p replace-regex (embeded-book-resources-html book-vec))))
            markdown-text
            re-matches)))


(defc mrd [text all-books]
  (-> text
      str
      replace-youtube
      (replace-book-resources all-books)
      md/md->hiccup
      md/component))

