(defn book-class-resources [all-books book-id state]
  (let [disp-book (when book-id ((keyword book-id) all-books))]
    [:div.content
     [:h1 [:i (:title disp-book)] " Classroom Resources"]
     (for [r (:resources disp-book)]
       (do
         (case (:type r)
           :video (embeded-youtube r)
           :mg-teaching-guide (mg-teaching-guid disp-book r)
           :hc-teaching-guide (hc-teaching-guild disp-book r)
           :md-page (md-book-resource disp-book r state)
           :else [:div])))
     [:h2 "Resources For Teaching My Other Books"]
     [:ul
      (for [[_ b] all-books]
        (when (and (not-empty (:resources b)) (not= (:uri b) book-id))
          [:li [:a {:href (str "/#class-resources/" (:uri b))} "Resources for teaching " [:i (:title b)]]]))]
     [:div.padding-bottom]]))

