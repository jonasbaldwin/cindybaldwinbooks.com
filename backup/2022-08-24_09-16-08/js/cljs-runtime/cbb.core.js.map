(defc md-page < rum/reactive [page all-books]
  (let [page-key (page-name-keyword page)
        page-contents (-> (rum/react state) page-key)
        title (->> (rum/react pages)
                   (filter #(= page-key (:state-key %)))
                   first
                   :title)]
    [:div.content
     [:h1 title]
     (mrd page-contents all-books)
     [:div.padding-bottom]]))

(defc bug [b]
  (let [{:keys [size margin-left]} b
        left-distance (- (/ (. js/window -innerWidth) 2) size)
        margin-left (if (neg? margin-left)
                      (max (- left-distance) margin-left)
                      (min left-distance margin-left))
        tool-style (condp = (:position b)
                     :bottom {"top"         "115%"
                              "left"        "50px"
                              "margin-left" "-60px"}
                     :top {"bottom"      "100%"
                           "left"        "50%"
                           "margin-left" "-60px"}
                     :left {"top"   "-5px"
                            "right" "115%"}
                     {"top"  "-5px"
                      "left" "115%"})]
    [:span.bug {:style {"height"      (str size "px")
                        "width"       (str size "px")
                        "margin-top"  (:margin-top b)
                        "margin-left" margin-left}}
     [:span.shake
      [:span {:class (name (:type b))
              :style {"height"          (str size "px")
                      "width"           (str size "px")
                      "background-size" (str size "px " size "px")
                      "transform"       (str "rotate(" (:rotate b) "deg)")}}]]
     (when (:hint b)
       [:span.hint-text
        {:style (merge {"width"     (str (:hint-width b) "px")}
                       tool-style)}
        (:hint b)])]))

(defn bugs [location page-id b]
  (println :page-id page-id)
  [:div.bugs
   (let [bs (filter #(= (or (keyword page-id) location) (:page %)) b)]
     (mapv #(bug %) bs))])


; ################################# root

(defc root < rum/reactive []
  (let [l (-> (rum/react location) :handler)
        navigation-links (-> (rum/react state) :misc :navigation-links)
        book-id (-> (rum/react location) :route-params :book-id)
        all-books (-> (rum/react state) :all-books)
        all-short-works (-> (rum/react state) :all-short-works :short-works)
        teaching-testimonials (-> (rum/react state) :misc :teaching-testimonials)
        writer-resc (-> (rum/react state) :misc :writer-resources)
        faqs (-> (rum/react state) :misc :faqs)
        page-id (-> (rum/react location) :route-params :page-id)]
    [:.application
     (bugs l page-id (-> (rum/react state) :misc :bugs))
     (when (not= l :home)
       (header l))
     (when (not= l :home)
       (main-nav-links l navigation-links page-id))
     (case l
       :home (home navigation-links)
       :press-kit (press-kit all-books)
       :events (events)
       :short-works (loading all-short-works (short-works all-short-works))
       :books (loading all-books (books all-books book-id))
       :class-resources (loading all-books (class-resources all-books book-id (rum/react state)))
       :writer-resources (writer-resources writer-resc)
       :faq (loading faqs (faq faqs))
       :page (loading page-id (md-page page-id all-books)))
     (social)]))

(defn ^:export start []
  (rum/mount (root) (.getElementById js/document "app"))
  (rum/mount (root) (.getElementById js/document "app")))
