    [:div.content "loading"]))

(defn embeded-youtube [item]
  (case (:platform item)
    :youtube [:div
              [:h2 (:title item)
               [:div.videoWrapper
                [:iframe
                 {:src             (str "https://www.youtube.com/embed/" (:video-id item) "?rel=0")
                  :frameborder     "0"
                  :allow           "autoplay; encrypted-media"
                  :allowfullscreen true}]]]]))

(defn embeded-youtube-html [item]
  (str "<div>
## " (:title item) "
<div class=\"videoWrapper\">
  <iframe src=\"" (str "https://www.youtube.com/embed/" (:video-id item) "?rel=0") "\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen=\"true\" />
</div>
</div>"))

(defn embeded-external-link-html [{:keys [text link]}]
  (str "<a href=\"" link "\" target=\"_blank\">" text "</a>"))

(defn embeded-book-resources-html [books]
  ;(when (not-empty (:resources b))
  ;  [:li [:a {:href (str "/#class-resources/" (:uri b))} "Book Resources for " [:i (:title b)]]])
  (let [book-links (for [b books]
                     (when (not-empty (:resources b))
                       (str "<li><a href=\"/#class-resources/" (:uri b) "\">" (:title b) "</a></li>")))]
    (str "<ul>"
         (apply str book-links)
         "</ul>")))

