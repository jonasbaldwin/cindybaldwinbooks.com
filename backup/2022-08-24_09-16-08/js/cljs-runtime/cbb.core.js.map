(defc show-quotes [title quotes location]
  (when-not (empty? quotes)
    [:div.quotes
     (if (= location :top) [:h3 "Praise for " [:i title]]
                           [:h3 "More praise for " [:i title]])
     (for [{:keys [text link]} (filter #(#{:indie} (:type %)) quotes)]
       [:div [:span.text
              (if link
                [:a {:href link :target "_blank"} text]
                text)]])
     (for [{:keys [text type author business link newbery-book new-york-times-bestseller]} (filter #(not= :indie (:type %)) quotes)]
       [:div {:class (name type)}
        [:span.text
         text
         (when (= :star-review type) " ★")]
        [:span.author
         (when author " ~ ")
         (when new-york-times-bestseller [:span "New York Times Bestelling Author of " [:i new-york-times-bestseller ", "]])
         author
         (when newbery-book [:span ", Newbery Honor-winning author of " [:i newbery-book]])
         (when (and author business) " from ")
         (if link
           [:a {:href link :target "_blank"}
            business
            (when (= :star-review type) ", Starred Review")]
           business)]])]))


(defc book [{:keys [title subtitle description notes quotes indie pub-date] :as book}]
  [:div
   [:div.content
    [:h1 title (when subtitle [:small subtitle])]
    [:div.book-info
     [:img.book-img {:src (-> book :images :front-cover)}]
     (affiliates/affiliate-link-list book)]
    (show-quotes title (filter #(= (:location %) :top) quotes) :top)
    (map-indexed (fn [i d]
                   [:p {:key (str (string/replace title #"\s" "_") "-" i)} d])
                 description)
    #_(for [d description]
        (let [key (string/replace (subs d 0 15) #"\s" "_")]
          [:p {:key key} d]))
    (show-quotes title (filter #(not= (:location %) :top) quotes) :bottom)]
   [:div.break]
   notes])

(defc books-list [all-books]
  (let [book-vec (->> all-books
                      (map second)
                      (filter #(book-active %))
                      sort-books-release)]
    [:div.content
     [:div
      (for [{:keys [title uri summary description brag] :as book} book-vec]
        [:div.clear.book-info-summary
         {:key title}
         [:div.book-info [:a {:href (str "/#books/" uri)} [:img.book-img {:src (-> book :images :front-cover)}]]]
         [:a {:href (str "/#books/" uri)} [:h2 title]]
         (when brag
           [(for [b brag]
              [:h3.plain {:key b} b])])
         [:p summary]                                       ;this is causing a key-props error for some reason
         [:p (first description) " "
          [:a {:href (str "/#books/" uri)} "Click here for more info."]]])]]))

(defc books
  "Displays the book requested, or a list of books."
  [all-books book-id]
  (let [disp-book (when book-id ((keyword book-id) all-books))] ;todo if title is close to the name of the book select it
    (if (and disp-book (:active disp-book))
      (book disp-book)
      (books-list all-books))))


