(enable-console-print!)

(defn page-name-keyword [name]
  (-> (string/replace-all (string/lower-case (str "page-" name)) #"\s" "-")
      keyword))

(defonce state (atom {}))
(defonce pages (atom []))

(defn update-state [k r t cb-fn]
  (case t
    :edn (swap! state assoc k (reader/read-string r))
    :md (swap! state assoc k r))
  (when cb-fn
    (cb-fn (reader/read-string r))))

(defn load
  ([file k] (load file k :edn))
  ([file k {:keys [var-type callback-fn] :or {var-type :edn}}]
   (ajax/GET file {:response-format :text
                   :handler         #(update-state k % var-type callback-fn)})))

(defn load-pages [data]
  (mapv (fn [{:keys [title source]}]
          (let [page-name (page-name-keyword title)]
            (load (str "pages/" source) page-name {:var-type    :md
                                                   :callback-fn (fn [_] (swap! pages conj {:title     title
                                                                                           :state-key page-name}))})))
        (:pages data)))

(defn load-book-resources [data]
  (mapv (fn [[_ {:keys [uri resources] :as b}]]
          (mapv (fn [{:keys [role source]}]
                  (when source
                    (let [resource-name (page-name-keyword (str (name role) "-" uri))]
                      (load (str "pages/" source) resource-name {:var-type :md}))))
                resources))
        data))

