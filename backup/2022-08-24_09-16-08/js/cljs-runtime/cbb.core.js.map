(defc main-nav-links [location navigation page-id]
  (let [navigation (->> navigation
                        (filter :display)
                        (sort-by :position))]
    [:div.navigation
     (for [n navigation]
       (let [class (case location
                     :page (when (= page-id (name (:name n))) "active ")
                     (when (= (:name n) location) "active "))
             class (-> (str (or class "") (string/replace (:link n) #"#" ""))
                       (string/replace #"/" "-"))
             attr (merge {:href (:link n) :class class :key (:name n)}
                         (when (:target n) {:target (:target n)}))]
         [:a
          attr
          [:span.link-text (:display n)]]))]))

; ################################# helpers

(def default-formatter (time-format/formatter "MMMM do, yyyy"))

(defn date-from-map [{:keys [day month year]}]
  (time/date-time year month day))

(defn format-date
  ([date] (format-date date (time-format/formatter "MMMM do, yyyy")))
  ([date formatter] (time-format/unparse formatter (date-from-map date))))

(defn book-active [book]
  (and (:active book) (> (time/now) (date-from-map (:display-date book)))))

(defn sort-books-release [all-books]
  (sort (fn [_ {:keys [pub-date]}]
          (str (:year pub-date) (:month pub-date) (:day pub-date)))
        all-books))

